<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quiz Mission Locale</title>
  <style>
    body {
      font-family: -apple-system, Arial, sans-serif;
      margin: 0;
      padding: 20px;
      background: #f2f2f2;
    }
    .container {
      max-width: 500px;
      margin: auto;
      background: white;
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    h1 {
      font-size: 20px;
      text-align: center;
    }
    .question {
      margin-bottom: 20px;
    }
    button {
      width: 100%;
      padding: 14px;
      margin: 6px 0;
      border: none;
      border-radius: 8px;
      background: #007BFF;
      color: white;
      font-size: 16px;
      cursor: pointer;
    }
    button:active {
      background: #0056b3;
    }
    .result {
      text-align: center;
      font-size: 18px;
      font-weight: bold;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Quel dispositif est fait pour toi ?</h1>
    <div id="quiz"></div>
    <div id="result" class="result"></div>
  </div>

  <script>
    const quizData = [
      {
        question: "Que fais-tu actuellement ?",
        answers: [
          { text: "Rien", type: "psad" },
          { text: "Je cherche un emploi", type: "emploi" },
          { text: "J'ai beaucoup de difficultés", type: "difficulte" }
        ]
      },
      {
        question: "As-tu un projet professionnel ?",
        answers: [
          { text: "Oui", type: "emploi" },
          { text: "Non", type: "psad" }
        ]
      },
      {
        question: "As-tu un logement stable ?",
        answers: [
          { text: "Oui", type: "none" },
          { text: "Non", type: "logement" }
        ]
      },
      {
        question: "As-tu des difficultés financières ?",
        answers: [
          { text: "Oui", type: "argent" },
          { text: "Non", type: "none" }
        ]
      },
      {
        question: "Veux-tu créer ton activité ?",
        answers: [
          { text: "Oui", type: "createur" },
          { text: "Non", type: "none" }
        ]
      },
      {
        question: "As-tu des difficultés avec le français ?",
        answers: [
          { text: "Oui", type: "kabar" },
          { text: "Non", type: "none" }
        ]
      },
      {
        question: "As-tu besoin d'aide pour ta santé ou ton moral ?",
        answers: [
          { text: "Oui", type: "sante" },
          { text: "Non", type: "none" }
        ]
      }
    ];

    let currentQuestion = 0;
    let scores = {
      psad: 0,
      emploi: 0,
      difficulte: 0,
      logement: 0,
      argent: 0,
      createur: 0,
      kabar: 0,
      sante: 0
    };

    function showQuestion() {
      const quiz = document.getElementById("quiz");
      quiz.innerHTML = "";

      if (currentQuestion >= quizData.length) {
        showResult();
        return;
      }

      const q = quizData[currentQuestion];

      const title = document.createElement("p");
      title.textContent = q.question;
      quiz.appendChild(title);

      q.answers.forEach(answer => {
        const btn = document.createElement("button");
        btn.textContent = answer.text;

        btn.addEventListener("click", function() {
          if (answer.type !== "none") {
            scores[answer.type]++;
          }
          currentQuestion++;
          showQuestion();
        });

        quiz.appendChild(btn);
      });
    }

    function showResult() {
      let maxType = Object.keys(scores).reduce((a, b) => scores[a] > scores[b] ? a : b);

      let message = "";

      switch(maxType) {
        case "psad":
          message = "👉 Dispositif conseillé : PSAD (remise en parcours)";
          break;
        case "emploi":
          message = "👉 Dispositif conseillé : Accompagnement vers l'emploi";
          break;
        case "difficulte":
          message = "👉 Dispositif conseillé : TAPAJ / BIP / Maison Relais";
          break;
        case "logement":
          message = "👉 Dispositif conseillé : Jeunes et Logés / ALT";
          break;
        case "argent":
          message = "👉 Dispositif conseillé : FDAJ / FUI";
          break;
        case "createur":
          message = "👉 Dispositif conseillé : Groupement de créateurs";
          break;
        case "kabar":
          message = "👉 Dispositif conseillé : Kabar M'Parano Jeunes";
          break;
        case "sante":
          message = "👉 Dispositif conseillé : Accompagnement santé";
          break;
      }

      document.getElementById("quiz").innerHTML = "";
      document.getElementById("result").textContent = message;
    }

    showQuestion();
  </script>
</body>
</html>
