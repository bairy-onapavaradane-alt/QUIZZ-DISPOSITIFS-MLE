<title>Quiz Mission Locale</title>
<style>
body { font-family: Arial; background:#f2f2f2; padding:20px; }
.container { max-width:500px; margin:auto; background:white; padding:20px; border-radius:10px; }
button { display:block; width:100%; padding:12px; margin:8px 0; background:#007BFF; color:white; border:none; border-radius:6px; font-size:16px; }
</style>
</head>
<body>
<div class="container">
<h2>Quel dispositif est fait pour toi ?</h2>
<p id="question"></p>
<div id="answers"></div>
<p id="result"></p>
</div>

<script>
var quiz = [
  {q:"Que fais-tu actuellement ?", a:[
    {t:"Rien", v:"psad"},
    {t:"Je cherche un emploi", v:"emploi"},
    {t:"J'ai des difficultés", v:"difficulte"}
  ]},
  {q:"As-tu un projet professionnel ?", a:[
    {t:"Oui", v:"emploi"},
    {t:"Non", v:"psad"}
  ]},
  {q:"As-tu un logement stable ?", a:[
    {t:"Oui", v:"none"},
    {t:"Non", v:"logement"}
  ]},
  {q:"As-tu des difficultés financières ?", a:[
    {t:"Oui", v:"argent"},
    {t:"Non", v:"none"}
  ]}
];

var i=0;
var score={psad:0, emploi:0, difficulte:0, logement:0, argent:0};

function show(){
  if(i>=quiz.length){
    var max="psad";
    for(var k in score){ if(score[k]>score[max]) max=k; }
    var res="";
    if(max=="psad") res="PSAD";
    if(max=="emploi") res="Accompagnement vers l'emploi";
    if(max=="difficulte") res="TAPAJ / BIP";
    if(max=="logement") res="Jeunes et Logés";
    if(max=="argent") res="FDAJ / FUI";
    document.getElementById("question").innerHTML="Résultat : "+res;
    document.getElementById("answers").innerHTML="";
    return;
  }

  document.getElementById("question").innerHTML=quiz[i].q;
  var div="";
  for(var j=0;j<quiz[i].a.length;j++){
    div += '<button onclick="next(\''+quiz[i].a[j].v+'\')">'+quiz[i].a[j].t+'</button>';
  }
  document.getElementById("answers").innerHTML=div;
}

function next(val){
  if(val!="none") score[val]++;
  i++;
  show();
}

show();
</script>
</body>
</html>
